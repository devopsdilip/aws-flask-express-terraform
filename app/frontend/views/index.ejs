<!DOCTYPE html>
<html>
<head>
    <title>Student Registration</title>
</head>
<body>

<h1>Student Registration</h1>

<form action="/add" method="POST">

    <label>Name</label>

    <input
        type="text"
        name="name"
        required>

    <br><br>

    <label>Course</label>

    <input
        type="text"
        name="course"
        required>

    <br><br>

    <button type="submit">
        Add Student
    </button>

</form>

<hr>

<h2>Student List</h2>

<ul>

<% students.forEach(student => { %>

<li>

<strong><%= student.name %></strong>

-

<%= student.course %>

</li>

<% }) %>

</ul>

</body>
</html>
